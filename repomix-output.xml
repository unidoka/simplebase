<file path="services/nginx/nginx.conf">
events {
    worker_connections 1024;
}

http {
    upstream main-service {
        server main-service:8000;
    }

    server {
        listen 80;

        location /api/main/v1/ {
            proxy_pass http://main-service/api/main/v1/;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        }

        location /health {
            proxy_pass http://main-service/health;
            proxy_set_header Host $host;
        }

    }
}
