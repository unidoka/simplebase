FROM python:3.12-slim
WORKDIR /app
COPY requirements/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY ./ /app/
CMD ["sh", "-c", "alembic upgrade head && uvicorn main:app --reload --host 0.0.0.0 --port 8000"]
